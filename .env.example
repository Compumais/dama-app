FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=troque-esta-chave-em-producao

APP_NAME=Coletor DAMA
ITEMS_PER_PAGE=20

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/coletor_dama
TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/coletor_dama_test

ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin123

# Chave compartilhada para autenticar o agent sincronizador no VPS
SYNC_API_KEY=troque-por-uma-chave-secreta

# Banco externo de produtos (consulta: select nome from produto where codigo = ?)
EXTERNAL_DB_HOST=localhost
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_NAME=seu_banco_externo
EXTERNAL_DB_USER=seu_usuario
EXTERNAL_DB_PASSWORD=sua_senha
EXTERNAL_DB_DRIVER=psycopg2

# Posições 1-based do código do produto no padrão MGV6 (conforme sua etiqueta)
MGV6_PRODUCT_CODE_START=2
MGV6_PRODUCT_CODE_END=5
MGV6_QTY_START=7
MGV6_QTY_END=12
MGV6_QTY_DECIMALS=3
