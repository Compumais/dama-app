# Conexao com o banco externo (onde existe tabela produto)
EXTERNAL_DB_HOST=localhost
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_NAME=seu_banco_externo
EXTERNAL_DB_USER=seu_usuario
EXTERNAL_DB_PASSWORD=sua_senha
EXTERNAL_DB_DRIVER=psycopg2

# API do VPS (onde o coletor roda)
# Exemplo: http://192.168.2.210:5000
VPS_API_URL=http://localhost:5000

# Chave compartilhada para autenticar sync
SYNC_API_KEY=troque-por-uma-chave-secreta

# Tamanho de lote para envio ao VPS
AGENT_BATCH_SIZE=500

# Intervalo do sync de produtos (segundos). 3600 = 1 hora.
SYNC_INTERVAL_SECONDS=3600

# Intervalo para baixar CSVs do VPS (finalizadas/) para a pasta local (segundos)
FINALIZADAS_POLL_SECONDS=5

# Pasta local onde os CSVs baixados do VPS sao gravados.
# Se vazio, usa ../finalizadas relativo ao agent.
FINALIZADAS_DIR=

